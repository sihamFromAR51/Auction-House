{
  "name": "auction-house",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "server": "npm run dev --prefix server",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "seed": "npm run seed --prefix server",
    "install:all": "npm install --prefix server && npm install --prefix client",
    "vercel-build": "cd client && npm run build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.2",
    "multer": "^1.4.5-lts.1",
    "validator": "^13.12.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
